{
  "name": "custom-integration-connector-api-bridge",
  "version": "1.0.0",
  "description": "Bidirectional API Bridge: Legacy SOAP/SQL ↔ Modern SaaS with rate-limiting, retries, and error logging",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "api-bridge",
    "soap",
    "sql",
    "graphql",
    "redis",
    "rate-limiter",
    "typescript"
  ],
  "license": "MIT",
  "dependencies": {
    "@apollo/server": "^4.11.0",
    "dotenv": "^16.4.5",
    "graphql": "^16.9.0",
    "graphql-tag": "^2.12.6",
    "ioredis": "^5.4.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
