# ─── Server ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Redis (rate limiter & retry state) ──────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Rate Limiter ───────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Retry (exponential backoff) ────────────────────────
RETRY_MAX_ATTEMPTS=5
RETRY_BASE_DELAY_MS=1000
RETRY_MAX_DELAY_MS=60000

# ─── Legacy SOAP ────────────────────────────────────────
SOAP_WSDL_URL=https://legacy.example.com/service?wsdl
SOAP_USERNAME=admin
SOAP_PASSWORD=password
SOAP_TIMEOUT_MS=10000

# ─── Legacy SQL ─────────────────────────────────────────
SQL_CONNECTION_STRING=postgresql://localhost:5432/legacy
SQL_SCHEMA=public
SQL_TIMEOUT_MS=5000

# ─── Sync Engine ────────────────────────────────────────
SYNC_POLL_INTERVAL_MS=30000
SYNC_BATCH_SIZE=50

# ─── Logging ────────────────────────────────────────────
LOG_LEVEL=info
LOG_PRETTY=true

# ═══════════════════════════════════════════════════════════
# 🔐 ENTERPRISE SECURITY CONFIGURATION
# ═══════════════════════════════════════════════════════════

# ─── JWT Authentication ─────────────────────────────────
# CHANGE THESE IN PRODUCTION! Use a strong random string (min 32 chars)
JWT_SECRET=change-this-to-a-strong-random-secret-at-least-32-chars
# Token expiry: e.g. 15m, 1h, 24h, 7d
JWT_EXPIRES_IN=1h

# ─── Encryption ─────────────────────────────────────────
# Used for AES-256-GCM encryption of sensitive data at rest
ENCRYPTION_KEY=change-this-to-another-strong-random-secret

# ─── Authentication Toggle ──────────────────────────────
# Set to false ONLY in development without sensitive data
AUTH_ENABLED=true

# ─── GraphQL Security ───────────────────────────────────
# Disable introspection in production to hide schema
GRAPHQL_INTROSPECTION=false
# Maximum allowed query depth (prevents deep recursive queries)
MAX_QUERY_DEPTH=7

# ─── CORS ───────────────────────────────────────────────
# Comma-separated list of allowed origins for the dashboard
CORS_ORIGINS=http://localhost:4001

# ─── Dashboard Auth ─────────────────────────────────────
DASHBOARD_AUTH_ENABLED=true
DASHBOARD_USERNAME=admin
# Set a strong password for dashboard access
DASHBOARD_PASSWORD=change-this-password

# ─── Payload Limits ─────────────────────────────────────
# Max JSON payload size for API requests (e.g. 1mb, 500kb)
MAX_PAYLOAD_SIZE=1mb
